{
  "name": "@zenith/shared-types",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "Shared TypeScript types and DTOs for Project Zenith",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@zenith/tsconfig": "*",
    "@zenith/eslint-config": "*",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
