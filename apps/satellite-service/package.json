{
  "name": "@zenith/satellite-service",
  "version": "0.1.0",
  "private": true,
  "description": "Project Zenith — Satellite microservice: SGP4 propagation, TLE management, pass prediction",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "@zenith/shared-types": "*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "satellite.js": "^5.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@zenith/eslint-config": "*",
    "@zenith/tsconfig": "*",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.9.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
