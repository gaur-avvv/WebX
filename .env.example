###############################################################################
# Project Zenith — Environment Variables Template
#
# Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all required values (marked with REQUIRED)
#   3. NEVER commit .env to version control
#   4. For production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
###############################################################################

# ─────────────────────────────────────────────
# GLOBAL APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────
# POSTGRESQL (Primary Database)
# ─────────────────────────────────────────────
POSTGRES_USER=zenith
# REQUIRED: Set a strong password (min 16 chars, mixed case + numbers + symbols)
POSTGRES_PASSWORD=
POSTGRES_DB=zenith_db
POSTGRES_PORT=5432
POSTGRES_REPLICA_PORT=5433

# Full connection URLs (constructed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public
DATABASE_REPLICA_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_REPLICA_PORT}/${POSTGRES_DB}?schema=public

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_PORT=6379
# REQUIRED: Set a strong Redis password
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}

# ─────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────
KAFKA_PORT=29092
KAFKA_BROKERS=localhost:29092

# ─────────────────────────────────────────────
# RABBITMQ
# ─────────────────────────────────────────────
RABBITMQ_USER=zenith
# REQUIRED: Set a strong RabbitMQ password
RABBITMQ_PASSWORD=

# ─────────────────────────────────────────────
# MONGODB
# ─────────────────────────────────────────────
MONGO_PORT=27017
MONGO_USER=zenith
# REQUIRED: Set a strong MongoDB password
MONGO_PASSWORD=
MONGODB_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@localhost:${MONGO_PORT}/zenith_analytics?authSource=admin

# ─────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────
# REQUIRED: Generate a 256-bit hex secret: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ─────────────────────────────────────────────
# EXTERNAL APIS
# ─────────────────────────────────────────────

# Cesium Ion Token — https://ion.cesium.com/tokens
# REQUIRED: Register for a free token at https://cesium.com/ion/
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# NASA Horizons API — no key required but respect rate limits (1 req/sec)
NASA_HORIZONS_API_URL=https://ssd.jpl.nasa.gov/api/horizons.api

# CelesTrak API — no key required but respect rate limits
CELESTRAK_API_URL=https://celestrak.org

# OpenNotify API — no key required
OPENNOTIFY_API_URL=http://api.open-notify.org

# ─────────────────────────────────────────────
# SERVICE URLS (local development)
# ─────────────────────────────────────────────
WEB_PORT=3000
SATELLITE_SERVICE_PORT=4001
PLANETARY_SERVICE_PORT=4002
NOTIFICATION_SERVICE_PORT=4003

NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4003
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# SATELLITE SERVICE CONFIG
# ─────────────────────────────────────────────
# How often to poll ISS position (milliseconds)
ISS_POLLING_INTERVAL_MS=5000
# TLE data cache TTL (seconds) — CelesTrak updates TLEs every few hours
TLE_CACHE_TTL_SECONDS=7200

# ─────────────────────────────────────────────
# PLANETARY SERVICE CONFIG
# ─────────────────────────────────────────────
# Planetary ephemeris cache TTL (seconds)
PLANETARY_CACHE_TTL_SECONDS=300

# ─────────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────────
GRAFANA_USER=admin
# REQUIRED: Set a strong Grafana admin password
GRAFANA_PASSWORD=
